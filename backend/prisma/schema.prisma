// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  runs      Run[]
  apiKeys   ApiKey[]
  evals     Eval[]
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  name       String
  key        String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
}

model Run {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  agentName String
  status    String   @default("running")
  totalMs   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  steps     Step[]
}

enum StepType {
  LLM_CALL
  TOOL_CALL
  ERROR
  RETRIEVAL
  MEMORY_READ
  MEMORY_WRITE
  AGENT_HANDOFF
  GUARDRAIL
  PLANNING
  LOOP_DETECTED
}

model Step {
  id        String   @id @default(cuid())
  runId     String
  run       Run      @relation(fields: [runId], references: [id])
  type      StepType
  error     String? 
  input     Json
  output    Json
  model     String?
  tool      String?
  tokens    Int?
  latencyMs Int?
  message   String?
  stack     String?
  state     Json?
  createdAt DateTime @default(now())
}

enum EvalStatus {
  COLLECTING
  IN_REVIEW
  OVERDUE
  COMPLETED
  ARCHIVED
  SCHEDULED
  DRAFT
}

model Eval {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  title       String
  description String?
  status      EvalStatus @default(DRAFT)
  assignee    String?
  dueDate     DateTime?
  agentName   String?
  criteria    Json?
  score       Float?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
